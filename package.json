{
  "name": "body-insight-ai",
  "version": "1.0.0",
  "private": true,
  "main": "main.js",
  "author": "Antigravity",
  "description": "Body Insight AI - Your Personal Health Advisor",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && npm run electron\"",
    "build:electron": "ELECTRON_BUILD=true next build",
    "dist": "npm run build:electron && electron-builder"
  },
  "build": {
    "appId": "com.bodyinsight.ai",
    "productName": "BodyInsightAI",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "main.js",
      "preload.js",
      "public/icon.png"
    ],
    "mac": {
      "category": "public.app-category.healthcare-fitness",
      "target": "dmg",
      "icon": "public/icon.png"
    }
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "date-fns": "^4.1.0",
    "electron-is-dev": "^2.0.0",
    "electron-serve": "^1.1.0",
    "firebase": "^12.13.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "papaparse": "^5.5.3",
    "pdf-parse": "^2.4.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-markdown": "^10.1.0",
    "recharts": "^2.12.7",
    "remark-gfm": "^4.0.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "concurrently": "^8.2.2",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8",
    "eslint-config-next": "16.2.4",
    "postcss": "^8",
    "tailwindcss": "^4.2.4",
    "typescript": "^5",
    "wait-on": "^7.2.0"
  }
}
